{
  "host": "127.0.0.1",
  "port": 8787,
  "strictStartup": false,
  "servers": [],
  "policy": {
    "mode": "hybrid",
    "tools": {
      "allow": ["*list*", "*read*", "*search*", "*issues*", "*pull*"],
      "deny": ["*delete*", "*create*", "*write*", "*push*", "*merge*"],
      "requireConfirmation": ["*fork*", "*branch*"]
    },
    "scope": {
      "paths": {
        "allow": [],
        "deny": []
      },
      "repos": {
        "allow": ["your-org/*"],
        "deny": []
      },
      "domains": {
        "allow": ["api.github.com", "github.com"],
        "deny": []
      }
    },
    "redaction": {
      "enabled": true,
      "extraPatterns": []
    },
    "defaults": {
      "onUnknownTool": "allow"
    }
  },
  "logging": {
    "level": "info",
    "filePath": "./logs/audit.log"
  }
}
