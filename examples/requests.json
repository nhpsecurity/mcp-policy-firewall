      }
    }
  },
  "blocked_tool_call": {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "filesystem__delete_file",
      "arguments": {
        "path": "README.md"
      }
    }
  }
