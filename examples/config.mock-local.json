{
  "host": "127.0.0.1",
  "port": 8787,
  "strictStartup": false,
  "servers": [
    {
      "name": "mockfs",
      "type": "stdio",
      "command": "node",
      "args": ["scripts/mock-mcp-server.cjs"],
      "timeoutMs": 10000
    }
  ],
  "policy": {
    "mode": "hybrid",
    "tools": {
      "allow": ["*read*", "*search*", "*list*", "*prompt*"],
      "deny": ["*delete*", "*write*", "*push*", "*remove*"],
      "requireConfirmation": []
    },
    "scope": {
      "paths": {
        "allow": ["."],
        "deny": [".env", ".git", "**/secrets/**"]
      },
      "repos": {
        "allow": [],
        "deny": []
      },
      "domains": {
        "allow": [],
        "deny": []
      }
    },
    "redaction": {
      "enabled": true,
      "extraPatterns": []
    },
    "defaults": {
      "onUnknownTool": "allow"
    }
  },
  "logging": {
    "level": "info",
    "filePath": "./logs/audit.log"
  }
}
